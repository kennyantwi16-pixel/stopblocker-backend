{
  "manifest_version": 3,
  "name": "Stop Blocker-Porn Blocker/adult site Blocker",
  "version": "1.0.2",
  "description": "Blocks porn websites and helps users stay focused.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },

  "permissions": [
    "storage",
    "tabs",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"

  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon48.png"
  },

  "options_page": "welcome.html",

  "incognito": "split"
}

